# AI Service Providers API Keys
MODELSCOPE_API_KEY=your_api_key_here
DEEPSEEK_API_KEY=your_api_key_here
MOONSHOT_API_KEY=your_api_key_here

# Current AI Provider (moonshot | deepseek | modelscope)
# If omitted, the backend picks the first configured API key in this order:
# modelscope -> deepseek -> moonshot.
AI_PROVIDER=modelscope

# API Server Port
PORT=3000
